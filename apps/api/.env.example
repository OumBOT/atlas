# ATLAS API — copier vers apps/api/.env
# Le port 5433 correspond à POSTGRES_PORT de infra/.env (5432 si défaut).
ATLAS_ENV=dev
ATLAS_DEBUG=true
ATLAS_DATABASE_URL=postgresql+asyncpg://atlas:changez-moi@localhost:5433/atlas
ATLAS_REDIS_URL=redis://localhost:6379/0

# Moteur de langage (ADR-002). Ollama natif recommandé sur Mac :
#   brew install ollama && brew services start ollama
#   ollama pull qwen2.5:7b-instruct
# Pour une API hébergée compatible OpenAI, changez base_url/model/api_key.
ATLAS_LLM_BASE_URL=http://localhost:11434/v1
ATLAS_LLM_MODEL=qwen2.5:7b-instruct
ATLAS_LLM_API_KEY=
